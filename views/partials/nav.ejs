<div class="navbar bg-base-200 shadow">
  <div class="container mx-auto max-w-3xl">
    <a href="/" class="btn btn-ghost text-xl normal-case">MessageBoard</a>
    <a href="/topics" class="btn btn-sm btn-ghost">Topics</a>
    <a href="/stats" class="btn btn-sm btn-ghost">Stats</a>
    <div class="ml-auto flex items-center gap-2">
      <% if (currentUser) { %>
        <a href="/notifications" class="btn btn-sm btn-ghost">
          Notifications
          <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %>
            <span class="badge badge-primary ml-1"><%= unreadCount %></span>
          <% } %>
        </a>
        <span class="text-sm opacity-70 hidden sm:inline">hi, <%= currentUser.username %></span>
        <form method="POST" action="/logout" class="inline">
          <button type="submit" class="btn btn-sm btn-ghost">Logout</button>
        </form>
      <% } else { %>
        <a href="/login" class="btn btn-sm btn-ghost">Login</a>
        <a href="/register" class="btn btn-sm btn-primary">Register</a>
      <% } %>
    </div>
  </div>
</div>
