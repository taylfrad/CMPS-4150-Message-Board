<div class="flex justify-between items-end mb-4">
  <h1 class="text-2xl font-bold">Stats</h1>
  <div class="text-sm opacity-70">
    <%= totalAccesses %> total access<%= totalAccesses === 1 ? '' : 'es' %> ·
    <%= totalMessages %> message<%= totalMessages === 1 ? '' : 's' %>
  </div>
</div>

<% if (topics.length === 0) { %>
  <div class="card bg-base-200">
    <div class="card-body text-center opacity-70">No topics yet.</div>
  </div>
<% } else { %>
  <div class="overflow-x-auto">
    <table class="table table-zebra">
      <thead>
        <tr>
          <th class="w-12 text-right">#</th>
          <th>Topic</th>
          <th>Author</th>
          <th class="text-right">Subscribers</th>
          <th class="text-right">Accesses</th>
        </tr>
      </thead>
      <tbody>
        <% topics.forEach(function (t, i) { %>
          <tr>
            <td class="text-right opacity-60"><%= i + 1 %></td>
            <td>
              <a href="/topics/<%= t._id %>" class="link link-hover font-semibold">
                <%= t.title %>
              </a>
            </td>
            <td><%= t.author ? t.author.username : '(deleted)' %></td>
            <td class="text-right"><%= (t.subscribers || []).length %></td>
            <td class="text-right font-mono"><%= t.accessCount || 0 %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>
