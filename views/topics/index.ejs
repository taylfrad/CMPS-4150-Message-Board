<div class="flex justify-between items-center mb-4">
  <h1 class="text-2xl font-bold">Topics</h1>
  <% if (currentUser) { %>
    <a href="/topics/new" class="btn btn-primary btn-sm">New topic</a>
  <% } %>
</div>

<% if (topics.length === 0) { %>
  <div class="card bg-base-200">
    <div class="card-body text-center opacity-70">
      No topics yet.
      <% if (currentUser) { %>
        <a href="/topics/new" class="link">Create the first one.</a>
      <% } else { %>
        <a href="/register" class="link">Register</a> to start one.
      <% } %>
    </div>
  </div>
<% } else { %>
  <div class="flex flex-col gap-3">
    <% topics.forEach(function (t) { %>
      <a href="/topics/<%= t._id %>" class="card bg-base-200 hover:bg-base-300 transition">
        <div class="card-body py-4">
          <h3 class="card-title"><%= t.title %></h3>
          <p class="text-sm opacity-70">
            by <%= t.author ? t.author.username : '(deleted)' %> ·
            <%= (t.subscribers || []).length %>
            subscriber<%= (t.subscribers || []).length === 1 ? '' : 's' %> ·
            <%= t.accessCount || 0 %>
            view<%= (t.accessCount || 0) === 1 ? '' : 's' %>
          </p>
        </div>
      </a>
    <% }) %>
  </div>
<% } %>
