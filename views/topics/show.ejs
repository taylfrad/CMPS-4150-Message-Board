<div class="mb-4 flex items-start justify-between gap-4">
  <div>
    <h1 class="text-2xl font-bold"><%= topic.title %></h1>
    <p class="text-sm opacity-70">
      by <%= topic.author ? topic.author.username : '(deleted)' %> ·
      <%= topic.subscribers.length %>
      subscriber<%= topic.subscribers.length === 1 ? '' : 's' %> ·
      <%= topic.accessCount || 0 %>
      view<%= (topic.accessCount || 0) === 1 ? '' : 's' %>
    </p>
  </div>
  <% if (currentUser) { %>
    <form method="POST" action="/topics/<%= topic._id %>/<%= isSubscribed ? 'unsubscribe' : 'subscribe' %>">
      <button type="submit" class="btn btn-sm <%= isSubscribed ? 'btn-ghost' : 'btn-primary' %>">
        <%= isSubscribed ? 'Unsubscribe' : 'Subscribe' %>
      </button>
    </form>
  <% } %>
</div>

<% if (topic.body) { %>
  <div class="card bg-base-200 mb-4">
    <div class="card-body py-4">
      <p class="whitespace-pre-wrap"><%= topic.body %></p>
    </div>
  </div>
<% } %>

<%- include('../partials/flash') %>

<h2 class="text-lg font-semibold mb-2">Messages</h2>
<div class="flex flex-col gap-2 mb-6">
  <% if (messages.length === 0) { %>
    <div class="opacity-60 text-sm">No messages yet. Be the first.</div>
  <% } %>
  <% messages.forEach(function (m) { %>
    <div class="card bg-base-200">
      <div class="card-body py-3">
        <div class="flex justify-between items-baseline gap-2">
          <span class="font-semibold"><%= m.author ? m.author.username : '(deleted)' %></span>
          <span class="text-xs opacity-50"><%= new Date(m.createdAt).toLocaleString() %></span>
        </div>
        <p class="whitespace-pre-wrap"><%= m.text %></p>
      </div>
    </div>
  <% }) %>
</div>

<% if (currentUser && isSubscribed) { %>
  <form method="POST" action="/topics/<%= topic._id %>/messages" class="flex flex-col gap-2">
    <textarea name="text" required maxlength="2000" rows="3"
              class="textarea textarea-bordered"
              placeholder="Write a message..."><%= values.text || '' %></textarea>
    <button type="submit" class="btn btn-primary self-end">Post</button>
  </form>
<% } else if (currentUser) { %>
  <div class="alert">
    <span>Subscribe to this topic to post a message.</span>
  </div>
<% } else { %>
  <div class="alert">
    <span>
      Please <a href="/login" class="link">login</a> to post or subscribe.
    </span>
  </div>
<% } %>
